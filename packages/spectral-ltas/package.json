{
  "name": "@audio/spectral-ltas",
  "version": "1.1.2",
  "description": "LTAS — long-term average spectrum via Welch's method (adaptive-EQ / match-EQ substrate)",
  "type": "module",
  "sideEffects": false,
  "main": "ltas.js",
  "exports": {
    ".": "./ltas.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "ltas.js",
    "audio.js",
    "audio.d.ts"
  ],
  "dependencies": {
    "fourier-transform": "^2.2.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "spectral",
    "ltas",
    "welch"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "audio": "./audio.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/spectral.git",
    "directory": "packages/spectral-ltas"
  }
}
